{
  "name": "nas-extension",
  "version": "5.0.7",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run build:chrome",
    "build:chrome": "node -e \"require('fs').copyFileSync('src/chrome_manifest.json','src/manifest.json')\" && ng build --configuration production,chrome",
    "build:firefox": "node -e \"require('fs').copyFileSync('src/firefox_manifest.json','src/manifest.json')\" && ng build --configuration production,firefox",
    "build:edge": "node -e \"require('fs').copyFileSync('src/chrome_manifest.json','src/manifest.json')\" && ng build --configuration production,edge",
    "watch:chrome": "node -e \"require('fs').copyFileSync('src/chrome_manifest.json','src/manifest.json')\" && ng build --watch --configuration development,chrome",
    "watch:firefox": "node -e \"require('fs').copyFileSync('src/firefox_manifest.json','src/manifest.json')\" && ng build --watch --configuration development,firefox",
    "pack:chrome": "npm run build:chrome && rm -f dist/nas-extension-chrome.zip && cd dist/nas-extension-chrome && zip -r ../nas-extension-chrome.zip .",
    "pack:firefox": "npm run build:firefox && ./pack_firefox.sh",
    "pack:edge": "npm run build:edge && rm -f dist/nas-extension-edge.zip && cd dist/nas-extension-edge && zip -r ../nas-extension-edge.zip .",
    "pack:all": "npm run pack:chrome && npm run pack:firefox && npm run pack:edge",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\"",
    "test": "ng test",
    "audit:fix": "npm audit fix"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "material-icons": "^1.13.14",
    "nas-logger": "^1.0.0",
    "nas-player": "^1.0.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.15",
    "@angular/build": "21.2.15",
    "@angular/cli": "21.2.15",
    "@angular/compiler-cli": "21.2.15",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.43",
    "@types/jasmine": "^6.0.0",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "^6.3.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "prettier": "^3.8.4",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.59.2"
  }
}
